<header class="site-header {% if settings.sticky_header %}site-header--sticky{% endif %}" id="SiteHeader" role="banner">
  <div class="container site-header__inner">

    <!-- Mobile Menu Toggle -->
    <button class="nav-toggle" id="NavToggle" aria-expanded="false" aria-controls="SiteNav" aria-label="Open navigation menu">
      <span class="nav-toggle__line"></span>
      <span class="nav-toggle__line"></span>
      <span class="nav-toggle__line"></span>
    </button>

    <!-- Logo -->
    <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }}">
      {% if settings.logo %}
        <img
          src="{{ settings.logo | image_url: width: settings.logo_width }}"
          alt="{{ shop.name }}"
          width="{{ settings.logo_width }}"
          loading="eager"
          class="site-header__logo-img"
        >
      {% else %}
        <img
          src="{{ 'logo.png' | asset_url }}"
          alt="{{ shop.name }}"
          width="{{ settings.logo_width | default: 160 }}"
          loading="eager"
          class="site-header__logo-img"
        >
      {% endif %}
    </a>

    <!-- Main Navigation -->
    <nav class="site-nav" id="SiteNav" aria-label="Main navigation">
      <ul class="site-nav__list" role="list">
        <li class="site-nav__item site-nav__item--has-dropdown">
          <a href="/collections/heritage-collection" class="site-nav__link" aria-haspopup="true">
            The Heritage Collection
            <svg class="site-nav__caret" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </a>
          <ul class="site-nav__dropdown" role="list">
            <li><a href="/collections/cushions-covers" class="site-nav__dropdown-link">Cushions &amp; Covers</a></li>
            <li><a href="/collections/wall-hangings" class="site-nav__dropdown-link">Wall Hangings</a></li>
            <li><a href="/collections/quilts-bed-runners" class="site-nav__dropdown-link">Quilts &amp; Bed Runners</a></li>
            <li><a href="/collections/tote-bags" class="site-nav__dropdown-link">Tote Bags</a></li>
          </ul>
        </li>

        <li class="site-nav__item site-nav__item--has-dropdown">
          <a href="/collections/ritual-kits" class="site-nav__link" aria-haspopup="true">
            The Ritual Kits
            <svg class="site-nav__caret" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </a>
          <ul class="site-nav__dropdown" role="list">
            <li><a href="/collections/starter-rituals" class="site-nav__dropdown-link">Starter Rituals</a></li>
            <li><a href="/collections/advanced-canvases" class="site-nav__dropdown-link">Advanced Canvases</a></li>
            <li><a href="/collections/decor-diy-kits" class="site-nav__dropdown-link">Decor DIY Kits</a></li>
            <li><a href="/collections/stick-stitch" class="site-nav__dropdown-link">Stick &amp; Stitch</a></li>
          </ul>
        </li>

        <li class="site-nav__item site-nav__item--has-dropdown">
          <a href="/collections/bundles-gifting" class="site-nav__link" aria-haspopup="true">
            Bundles &amp; Gifting
            <svg class="site-nav__caret" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </a>
          <ul class="site-nav__dropdown" role="list">
            <li><a href="/collections/ritual-kit-for-two" class="site-nav__dropdown-link">Ritual Kit for Two</a></li>
            <li><a href="/collections/bridesmaid-wedding" class="site-nav__dropdown-link">Bridesmaid &amp; Wedding</a></li>
            <li><a href="/collections/mom-me-set" class="site-nav__dropdown-link">The Mom &amp; Me Set</a></li>
            <li><a href="/products/gift-card" class="site-nav__dropdown-link">Gift Cards</a></li>
          </ul>
        </li>

        <li class="site-nav__item">
          <a href="/pages/corporate-workshops" class="site-nav__link">Corporate &amp; Workshops</a>
        </li>

        <li class="site-nav__item">
          <a href="/collections/new-arrivals" class="site-nav__link">New Arrivals</a>
        </li>

        <li class="site-nav__item">
          <a href="/pages/our-story" class="site-nav__link">Our Story</a>
        </li>
      </ul>
    </nav>

    <!-- Header Actions -->
    <div class="site-header__actions">
      <!-- Search -->
      <button class="header-icon-btn" id="SearchToggle" aria-label="Search" aria-expanded="false">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      </button>

      <!-- Account -->
      <a href="{{ routes.account_url }}" class="header-icon-btn" aria-label="Account">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>

      <!-- Cart -->
      <button class="header-icon-btn cart-btn" id="CartToggle" aria-label="Open cart" aria-expanded="false">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="cart-count" id="CartCount" {% unless cart.item_count > 0 %}hidden{% endunless %}>{{ cart.item_count }}</span>
      </button>
    </div>

  </div>

  <!-- Search Bar (hidden by default) -->
  <div class="search-bar" id="SearchBar" aria-hidden="true">
    <div class="container search-bar__inner">
      <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
        <input type="search" name="q" placeholder="Search for kits, decor, gifts..." class="search-form__input" aria-label="Search">
        <button type="submit" class="search-form__submit btn btn--primary">Search</button>
      </form>
      <button class="search-bar__close" id="SearchClose" aria-label="Close search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>
