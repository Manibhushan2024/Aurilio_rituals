<footer class="site-footer" role="contentinfo">
  <div class="site-footer__top">
    <div class="container site-footer__grid">

      <!-- Brand Column -->
      <div class="site-footer__brand">
        {% if settings.logo %}
          <img src="{{ settings.logo | image_url: width: 140 }}" alt="{{ shop.name }}" class="site-footer__logo" width="140" height="76" loading="lazy">
        {% else %}
          <!-- Inline SVG — footer variant (cream + gold on dark) -->
          <svg class="site-footer__logo-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 108" aria-label="{{ shop.name }}" role="img">
            <title>{{ shop.name }}</title>
            <g transform="translate(100,36)" fill="#E2C99E">
              <path d="M0,0 C-4.5,-8 -4.5,-17 0,-20 C4.5,-17 4.5,-8 0,0Z"/>
              <path d="M0,0 C-4.5,-8 -4.5,-17 0,-20 C4.5,-17 4.5,-8 0,0Z" transform="rotate(90)"/>
              <path d="M0,0 C-4.5,-8 -4.5,-17 0,-20 C4.5,-17 4.5,-8 0,0Z" transform="rotate(180)"/>
              <path d="M0,0 C-4.5,-8 -4.5,-17 0,-20 C4.5,-17 4.5,-8 0,0Z" transform="rotate(270)"/>
              <path d="M0,0 C-3,-6 -3,-13 0,-15 C3,-13 3,-6 0,0Z" transform="rotate(45)"  opacity="0.6"/>
              <path d="M0,0 C-3,-6 -3,-13 0,-15 C3,-13 3,-6 0,0Z" transform="rotate(135)" opacity="0.6"/>
              <path d="M0,0 C-3,-6 -3,-13 0,-15 C3,-13 3,-6 0,0Z" transform="rotate(225)" opacity="0.6"/>
              <path d="M0,0 C-3,-6 -3,-13 0,-15 C3,-13 3,-6 0,0Z" transform="rotate(315)" opacity="0.6"/>
              <circle cx="0"     cy="-25"   r="1.4"/><circle cx="17.7"  cy="-17.7" r="1.4"/>
              <circle cx="25"    cy="0"     r="1.4"/><circle cx="17.7"  cy="17.7"  r="1.4"/>
              <circle cx="0"     cy="25"    r="1.4"/><circle cx="-17.7" cy="17.7"  r="1.4"/>
              <circle cx="-25"   cy="0"     r="1.4"/><circle cx="-17.7" cy="-17.7" r="1.4"/>
              <circle cx="0" cy="0" r="4"/><circle cx="0" cy="0" r="1.8" fill="#2C2C2C" opacity="0.4"/>
            </g>
            <text x="100" y="70" text-anchor="middle" font-family="Georgia,'Times New Roman',serif" font-size="22" letter-spacing="4" fill="#FAF6F0">AURILIO</text>
            <line x1="30"  y1="79" x2="88"  y2="79" stroke="#E2C99E" stroke-width="0.65"/>
            <circle cx="100" cy="79" r="2.2" fill="#E2C99E"/>
            <line x1="112" y1="79" x2="170" y2="79" stroke="#E2C99E" stroke-width="0.65"/>
            <text x="100" y="95" text-anchor="middle" font-family="Georgia,'Times New Roman',serif" font-size="10" letter-spacing="6" fill="#E2C99E">RITUALS</text>
          </svg>
        {% endif %}
        <p class="site-footer__tagline">{{ settings.footer_tagline }}</p>
        <p class="site-footer__desc">Premium Sujni embroidery kits &amp; heritage home decor. Mindfully crafted by skilled Indian artisans.</p>

        <!-- Social Links -->
        <div class="site-footer__social" aria-label="Social media links">
          {% if settings.social_instagram_url != blank %}
          <a href="{{ settings.social_instagram_url }}" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Instagram" class="social-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          {% endif %}
          {% if settings.social_pinterest_url != blank %}
          <a href="{{ settings.social_pinterest_url }}" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Pinterest" class="social-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.236 2.636 7.855 6.356 9.312-.088-.791-.167-2.005.035-2.868.181-.78 1.172-4.97 1.172-4.97s-.299-.598-.299-1.482c0-1.388.806-2.428 1.808-2.428.852 0 1.265.64 1.265 1.408 0 .858-.546 2.14-.828 3.33-.236.995.498 1.806 1.476 1.806 1.772 0 3.137-1.868 3.137-4.568 0-2.39-1.718-4.06-4.168-4.06-2.839 0-4.505 2.129-4.505 4.332 0 .858.33 1.776.742 2.279a.297.297 0 0 1 .068.284c-.076.312-.243.995-.276 1.134-.044.183-.146.222-.337.134-1.249-.581-2.03-2.407-2.03-3.874 0-3.154 2.292-6.052 6.608-6.052 3.469 0 6.165 2.473 6.165 5.776 0 3.447-2.173 6.22-5.19 6.22-1.013 0-1.966-.527-2.292-1.148l-.623 2.378c-.226.869-.835 1.958-1.244 2.621.937.29 1.931.446 2.962.446 5.523 0 10-4.477 10-10S17.523 2 12 2z"/></svg>
          </a>
          {% endif %}
          {% if settings.social_youtube_url != blank %}
          <a href="{{ settings.social_youtube_url }}" target="_blank" rel="noopener noreferrer" aria-label="Watch us on YouTube" class="social-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.96-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
          </a>
          {% endif %}
          <!-- WhatsApp -->
          <a href="https://wa.me/{{ settings.footer_whatsapp | remove: '+' | remove: ' ' }}" target="_blank" rel="noopener noreferrer" aria-label="Contact us on WhatsApp" class="social-link social-link--whatsapp">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </a>
        </div>
      </div>

      <!-- Shop Column -->
      <div class="site-footer__col">
        <h3 class="site-footer__heading">Shop</h3>
        <ul class="site-footer__links" role="list">
          <li><a href="/collections/heritage-collection">The Heritage Collection</a></li>
          <li><a href="/collections/ritual-kits">The Ritual Kits</a></li>
          <li><a href="/collections/bundles-gifting">Bundles &amp; Gifting</a></li>
          <li><a href="/collections/new-arrivals">New Arrivals</a></li>
          <li><a href="/collections/best-sellers">Best Sellers</a></li>
        </ul>
      </div>

      <!-- Learn Column -->
      <div class="site-footer__col">
        <h3 class="site-footer__heading">Learn</h3>
        <ul class="site-footer__links" role="list">
          <li><a href="/pages/our-story">Our Story</a></li>
          <li><a href="/pages/corporate-workshops">Corporate &amp; Workshops</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
          <li><a href="/pages/contact">Contact Us</a></li>
        </ul>
      </div>

      <!-- Policies Column -->
      <div class="site-footer__col">
        <h3 class="site-footer__heading">Policies</h3>
        <ul class="site-footer__links" role="list">
          <li><a href="{{ shop.privacy_policy.url }}">Privacy Policy</a></li>
          <li><a href="{{ shop.refund_policy.url }}">Returns &amp; Exchanges</a></li>
          <li><a href="{{ shop.shipping_policy.url }}">Shipping Policy</a></li>
          <li><a href="{{ shop.terms_of_service.url }}">Terms of Service</a></li>
        </ul>
      </div>

      <!-- Contact Column -->
      <div class="site-footer__col">
        <h3 class="site-footer__heading">Get in Touch</h3>
        <ul class="site-footer__contact" role="list">
          <li>
            <a href="mailto:{{ settings.footer_email }}" class="site-footer__contact-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              {{ settings.footer_email }}
            </a>
          </li>
          <li>
            <a href="https://wa.me/{{ settings.footer_whatsapp | remove: '+' | remove: ' ' }}" class="site-footer__contact-link" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              +91 9334892585
            </a>
          </li>
          <li>
            <a href="tel:+919334892585" class="site-footer__contact-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.29 6.29l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              +91 9334892585
            </a>
          </li>
        </ul>
        <!-- Newsletter mini -->
        <div class="site-footer__newsletter">
          <p class="site-footer__newsletter-label">Join the ritual</p>
          {% form 'customer', id: 'FooterNewsletterForm' %}
            <div class="site-footer__newsletter-group">
              <input type="email" name="contact[email]" placeholder="your@email.com" class="site-footer__newsletter-input" aria-label="Email for newsletter" required>
              <button type="submit" class="site-footer__newsletter-btn" aria-label="Subscribe">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>
            </div>
          {% endform %}
        </div>
      </div>

    </div>
  </div>

  <!-- Footer Bottom -->
  <div class="site-footer__bottom">
    <div class="container site-footer__bottom-inner">
      <p class="site-footer__copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved. Made with love &amp; Sujni thread.</p>
      <div class="site-footer__payments" aria-label="Accepted payment methods">
        <span class="payment-badge">Visa</span>
        <span class="payment-badge">Mastercard</span>
        <span class="payment-badge">UPI</span>
        <span class="payment-badge">Razorpay</span>
      </div>
    </div>
  </div>
</footer>
