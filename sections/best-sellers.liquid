{% assign collection = section.settings.collection %}
{% assign products = collection.products | default: recommendations.products %}

<section class="best-sellers section" id="BestSellers" aria-label="Best sellers">
  <div class="container">

    <div class="section-header animate-fade-up">
      {% if section.settings.eyebrow != blank %}
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="section-subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="product-grid product-grid--{{ section.settings.columns_desktop }}">
      {% if collection != blank %}
        {% for product in collection.products limit: section.settings.products_limit %}
          {% render 'product-card', product: product, show_badge: true %}
        {% else %}
          {% for i in (1..section.settings.products_limit) %}
            <div class="product-card product-card--placeholder">
              <div class="product-card__media skeleton"></div>
              <div class="product-card__info">
                <div class="skeleton skeleton--line" style="width:60%;height:14px;margin-bottom:8px;"></div>
                <div class="skeleton skeleton--line" style="width:40%;height:14px;"></div>
              </div>
            </div>
          {% endfor %}
        {% endfor %}
      {% else %}
        {% for product in section.settings.featured_products limit: section.settings.products_limit %}
          {% render 'product-card', product: product, show_badge: true %}
        {% else %}
          {% for i in (1..4) %}
            <div class="product-card product-card--placeholder">
              <div class="product-card__media skeleton"></div>
            </div>
          {% endfor %}
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.show_view_all and section.settings.view_all_url != blank %}
      <div class="section-footer animate-fade-up">
        <a href="{{ section.settings.view_all_url }}" class="btn btn--outline" id="BestSellerViewAll">
          {{ section.settings.view_all_label | default: 'View All' }}
        </a>
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Best Sellers",
  "tag": "section",
  "class": "section-best-sellers",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Most Loved"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Best Sellers"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our community's all-time favourites. Stitched with love, delivered with care."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Choose Collection (for auto products)"
    },
    {
      "type": "product_list",
      "id": "featured_products",
      "label": "Featured Products (overrides collection)",
      "limit": 8
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Number of Products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (Desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All Button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View All Label",
      "default": "View All Best Sellers"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View All URL"
    }
  ],
  "presets": [
    {
      "name": "Best Sellers",
      "eyebrow": "Most Loved",
      "heading": "Best Sellers",
      "subheading": "Our community's all-time favourites.",
      "products_limit": 4,
      "columns_desktop": "4"
    }
  ]
}
{% endschema %}
