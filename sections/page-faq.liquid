<div class="page-faq">

  <!-- FAQ Hero -->
  <section class="page-hero page-hero--compact section--cream" id="FaqHero">
    <div class="container page-hero__content animate-fade-up">
      <p class="section-eyebrow">Help & Support</p>
      <h1 class="page-hero__title">Frequently Asked Questions</h1>
      <p class="page-hero__subtitle">Everything you need to know about your Aurilio Rituals experience.</p>
    </div>
  </section>

  <!-- FAQ Accordion -->
  <section class="faq-section section" id="FaqSection">
    <div class="container faq-section__inner">

      <div class="faq-list" id="FaqList">
        {% for block in section.blocks %}
          {% if block.type == 'faq_item' %}
            <details class="faq-item" {{ block.shopify_attributes }} id="Faq{{ forloop.index }}">
              <summary class="faq-item__question">
                {{ block.settings.question }}
                <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer rte">
                {{ block.settings.answer }}
              </div>
            </details>
          {% endif %}
        {% endfor %}
      </div>

      <!-- Still have questions -->
      <div class="faq-contact-cta animate-fade-up">
        <h2 class="faq-contact-cta__heading">Still have questions?</h2>
        <p class="faq-contact-cta__desc">We're just a WhatsApp message away. Reach out — we love hearing from our community!</p>
        <div class="faq-contact-cta__btns">
          <a href="https://wa.me/{{ settings.footer_whatsapp | remove: '+' | remove: ' ' }}" target="_blank" rel="noopener noreferrer" class="btn btn--primary" id="FaqWhatsApp">Chat on WhatsApp</a>
          <a href="mailto:{{ settings.footer_email }}" class="btn btn--outline" id="FaqEmail">Email Us</a>
        </div>
      </div>

    </div>
  </section>

</div>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section-faq",
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        { "type": "text",     "id": "question", "label": "Question", "default": "What is in a Ritual Kit?" },
        { "type": "richtext", "id": "answer",   "label": "Answer",   "default": "<p>Each Ritual Kit includes a premium wooden embroidery hoop, pre-printed pattern fabric with authentic Sujni-inspired designs, a curated thread bundle, needle kit, and a QR code for access to our step-by-step video tutorials. No experience needed!</p>" }
      ]
    }
  ],
  "presets": [{
    "name": "FAQ Page",
    "blocks": [
      { "type": "faq_item", "settings": { "question": "What exactly is inside a Ritual Kit?", "answer": "<p>Every kit includes: a premium wooden embroidery hoop (6\" or 8\"), a pre-printed Sujni pattern fabric, a curated embroidery thread bundle, a full needle kit (needles, threader, cutter, needle minder), and QR-code access to step-by-step video tutorials. Beginners welcome!</p>" } },
      { "type": "faq_item", "settings": { "question": "I've never embroidered before — are these for me?", "answer": "<p>Absolutely, yes! 100% beginner-friendly. Our kits are designed with care so that anyone — regardless of experience — can follow along and create something beautiful. Our video tutorials guide you stitch by stitch.</p>" } },
      { "type": "faq_item", "settings": { "question": "How do I access the video tutorials?", "answer": "<p>Every kit includes a printed QR code card. Simply scan it with your phone and you'll be taken to our private tutorial library where your kit's full video guide is waiting for you.</p>" } },
      { "type": "faq_item", "settings": { "question": "How long does shipping take within India?", "answer": "<p>We dispatch orders within 2–3 business days. Standard delivery takes 5–7 business days. Express options may be available at checkout depending on your location.</p>" } },
      { "type": "faq_item", "settings": { "question": "Do you offer international shipping?", "answer": "<p>Yes! We ship to select international destinations. International shipping timelines and costs are calculated at checkout. Reach out to us on WhatsApp for specific country queries.</p>" } },
      { "type": "faq_item", "settings": { "question": "What is your return and exchange policy?", "answer": "<p>We offer mindful returns within 7 days of delivery for unopened, unused products in original packaging. Please WhatsApp or email us and we'll guide you through the process warmly.</p>" } },
      { "type": "faq_item", "settings": { "question": "Can I place bulk orders for weddings or corporate events?", "answer": "<p>Yes! We love creating custom bulk orders. Whether it's a bridesmaid ritual box or a corporate wellness gifting project, reach out to us at hello@aureliarituals.com or WhatsApp for a personalised quote.</p>" } },
      { "type": "faq_item", "settings": { "question": "How does my purchase impact artisans?", "answer": "<p>Every product you buy from Aurilio Rituals directly supports our artisan collective. A portion of revenue goes directly to artisan earnings. We don't believe in charity — we believe in fair trade, skill recognition, and sustainable livelihoods.</p>" } }
    ]
  }]
}
{% endschema %}
