<section class="story-preview section section--cream" id="StoryPreview" aria-label="Our story">
  <div class="container story-preview__inner">

    <!-- Image Side -->
    <div class="story-preview__media animate-fade-up">
      {% if section.settings.image %}
        <img
          src="{{ section.settings.image | image_url: width: 700 }}"
          srcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 700 }} 700w"
          sizes="(max-width: 767px) 100vw, 50vw"
          alt="{{ section.settings.image_alt | default: 'Our artisans at work' }}"
          class="story-preview__img"
          loading="lazy"
          width="700"
          height="840"
        >
      {% else %}
        <img
          src="{{ 'homepage-story-preview.png' | asset_url }}"
          sizes="(max-width: 767px) 100vw, 50vw"
          alt="{{ section.settings.image_alt | default: 'Our artisans at work' }}"
          class="story-preview__img"
          loading="lazy"
          width="700"
          height="840"
        >
      {% endif %}
      <!-- Decorative gold frame -->
      <div class="story-preview__frame" aria-hidden="true"></div>
    </div>

    <!-- Text Side -->
    <div class="story-preview__content animate-fade-up" style="animation-delay:150ms;">
      {% if section.settings.eyebrow != blank %}
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="section-heading story-preview__heading">{{ section.settings.heading }}</h2>
      <div class="story-preview__body rte">
        {{ section.settings.body_text }}
      </div>

      <!-- Stats Row -->
      {% if section.settings.show_stats %}
      <div class="story-preview__stats" aria-label="Impact statistics">
        <div class="story-stat">
          <strong class="story-stat__number">{{ section.settings.stat1_number }}</strong>
          <span class="story-stat__label">{{ section.settings.stat1_label }}</span>
        </div>
        <div class="story-divider" aria-hidden="true"></div>
        <div class="story-stat">
          <strong class="story-stat__number">{{ section.settings.stat2_number }}</strong>
          <span class="story-stat__label">{{ section.settings.stat2_label }}</span>
        </div>
        <div class="story-divider" aria-hidden="true"></div>
        <div class="story-stat">
          <strong class="story-stat__number">{{ section.settings.stat3_number }}</strong>
          <span class="story-stat__label">{{ section.settings.stat3_label }}</span>
        </div>
      </div>
      {% endif %}

      {% if section.settings.cta_label != blank %}
        <a href="{{ section.settings.cta_url }}" class="btn btn--primary" id="StoryPreviewCTA">
          {{ section.settings.cta_label }}
        </a>
      {% endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Story Preview",
  "tag": "section",
  "class": "section-story-preview",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Artisan / Story Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text",
      "default": "Skilled artisan creating Sujni embroidery"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Real Women. Real Art."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Heritage Woven into Every Thread."
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body Text",
      "default": "<p>Aurilio Rituals was born from a deep reverence for the ancient Sujni embroidery tradition of Bihar. Each piece — whether a finished cushion or a DIY kit — carries within it the pride, skill, and artistry of the women who make them possible.</p><p>We believe in slow making, intentional living, and the quiet power of creation. Our ritual kits invite you to pause, breathe, and stitch your own story.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_stats",
      "label": "Show Impact Statistics",
      "default": true
    },
    {
      "type": "text",
      "id": "stat1_number",
      "label": "Stat 1 — Number",
      "default": "200+"
    },
    {
      "type": "text",
      "id": "stat1_label",
      "label": "Stat 1 — Label",
      "default": "Artisans Supported"
    },
    {
      "type": "text",
      "id": "stat2_number",
      "label": "Stat 2 — Number",
      "default": "5000+"
    },
    {
      "type": "text",
      "id": "stat2_label",
      "label": "Stat 2 — Label",
      "default": "Rituals Started"
    },
    {
      "type": "text",
      "id": "stat3_number",
      "label": "Stat 3 — Number",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat3_label",
      "label": "Stat 3 — Label",
      "default": "Handcrafted"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Label",
      "default": "Read Our Story"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [
    {
      "name": "Story Preview",
      "eyebrow": "Real Women. Real Art.",
      "heading": "Heritage Woven into Every Thread."
    }
  ]
}
{% endschema %}
