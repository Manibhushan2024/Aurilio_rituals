<section class="artisan-video-section section" id="ArtisanVideo" aria-label="Watch the ritual">
  <div class="container artisan-video-section__inner">

    <!-- Text side -->
    <div class="artisan-video-section__text animate-fade-up">
      {% if section.settings.eyebrow != blank %}
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="section-heading">{{ section.settings.heading | default: 'Watch the Ritual Come Alive' }}</h2>
      <div class="rte artisan-video-section__body">
        {{ section.settings.body | default: '<p>Every stitch is an act of intention. Watch how skilled artisans bring centuries of Sujni tradition into a single, mindful canvas, and discover how you can be part of this living art form.</p>' }}
      </div>
      {% if section.settings.cta_label != blank %}
        <a href="{{ section.settings.cta_url | default: '/collections/ritual-kits' }}" class="btn btn--primary" id="ArtisanVideoCTA">
          {{ section.settings.cta_label }}
        </a>
      {% endif %}
    </div>

    <!-- Video side -->
    <div class="artisan-video-section__media animate-fade-up" style="animation-delay:180ms;">
      <div class="artisan-video-section__video-wrap">

        {% if section.settings.video_type == 'youtube' and section.settings.youtube_id != blank %}
          <div class="artisan-video-section__iframe-wrap">
            <iframe
              src="https://www.youtube.com/embed/{{ section.settings.youtube_id }}?autoplay=0&rel=0&modestbranding=1"
              title="{{ section.settings.heading | default: 'Artisan ritual video' }}"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
              class="artisan-video-section__iframe"
            ></iframe>
          </div>

        {% elsif section.settings.video_type == 'file' %}
          <video
            class="artisan-video-section__video"
            {% if section.settings.autoplay %}autoplay muted loop playsinline{% endif %}
            controls
            poster="{{ section.settings.video_poster | image_url: width: 800 }}"
          >
            {% if section.settings.video_file != blank %}
              <source src="{{ section.settings.video_file }}" type="video/mp4">
            {% else %}
              <source src="{{ 'artisan-ritual.mp4' | asset_url }}" type="video/mp4">
            {% endif %}
          </video>

        {% else %}
          <!-- Fallback: image with play overlay -->
          <div class="artisan-video-section__img-play" id="VideoPlayTrigger">
            {% if section.settings.cover_image %}
              <img
                src="{{ section.settings.cover_image | image_url: width: 800 }}"
                alt="{{ section.settings.heading | default: 'Watch the artisan ritual' }}"
                class="artisan-video-section__cover parallax-img"
                loading="lazy"
                width="800"
                height="540"
              >
            {% else %}
              <img
                src="{{ 'artisan-story.jpg' | asset_url }}"
                alt="Artisan at work"
                class="artisan-video-section__cover parallax-img"
                loading="lazy"
                width="800"
                height="540"
              >
            {% endif %}
            <button class="artisan-video-section__play-btn" aria-label="Play video">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </button>
          </div>
        {% endif %}

      </div>

      {% if section.settings.caption != blank %}
        <p class="artisan-video-section__caption">{{ section.settings.caption }}</p>
      {% endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Artisan Video",
  "tag": "section",
  "class": "section-artisan-video",
  "settings": [
    { "type": "text",        "id": "eyebrow",      "label": "Eyebrow",        "default": "The Ritual in Motion" },
    { "type": "text",        "id": "heading",       "label": "Heading",        "default": "Watch the Ritual Come Alive" },
    { "type": "richtext",    "id": "body",          "label": "Body Text" },
    { "type": "text",        "id": "cta_label",     "label": "CTA Label",      "default": "Start Your Ritual" },
    { "type": "url",         "id": "cta_url",       "label": "CTA Link" },
    { "type": "header",      "content": "Video Settings" },
    {
      "type": "select",
      "id": "video_type",
      "label": "Video Type",
      "options": [
        { "value": "image", "label": "Image with Play Button" },
        { "value": "youtube", "label": "YouTube Embed" },
        { "value": "file", "label": "Video File (MP4)" }
      ],
      "default": "image"
    },
    { "type": "text",        "id": "youtube_id",    "label": "YouTube Video ID (e.g. dQw4w9WgXcQ)" },
    { "type": "image_picker","id": "cover_image",   "label": "Cover Image / Thumbnail" },
    { "type": "text",        "id": "video_file",    "label": "Video File URL (MP4)" },
    { "type": "image_picker","id": "video_poster",  "label": "Video Poster Image" },
    { "type": "checkbox",    "id": "autoplay",      "label": "Autoplay (muted, looping)", "default": false },
    { "type": "text",        "id": "caption",       "label": "Caption below video", "default": "Filmed with our artisan collective." },
    { "type": "header",      "content": "Layout" },
    {
      "type": "select",
      "id": "layout",
      "label": "Text Position",
      "options": [
        { "value": "text_left", "label": "Text Left, Video Right" },
        { "value": "text_right", "label": "Text Right, Video Left" }
      ],
      "default": "text_left"
    }
  ],
  "presets": [{ "name": "Artisan Video" }]
}
{% endschema %}
