[
  {
    "name": "theme_info",
    "theme_name": "Aurelia Rituals",
    "theme_version": "1.0.0",
    "theme_documentation_url": "https://github.com/aurelia-rituals/shopify-theme",
    "theme_author": "Aurelia Rituals Studio",
    "theme_support_url": "mailto:hello@aureliarituals.com"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary – Soft Gold",
        "default": "#C9A96E"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary – Muted Terracotta",
        "default": "#C47A55"
      },
      {
        "type": "color",
        "id": "color_bg",
        "label": "Background – Cream",
        "default": "#FAF6F0"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Body Text – Charcoal",
        "default": "#2C2C2C"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent – Soft Grey",
        "default": "#8E8E8E"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Surface – Warm White",
        "default": "#FFFFFF"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading Font",
        "default": "cormorant_garamond_n4"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body Font",
        "default": "inter_n4"
      },
      {
        "type": "range",
        "id": "font_size_base",
        "label": "Base Font Size (px)",
        "min": 14,
        "max": 20,
        "step": 1,
        "default": 16
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo Width (px)",
        "min": 80,
        "max": 300,
        "step": 10,
        "default": 160
      },
      {
        "type": "text",
        "id": "announcement_text",
        "label": "Announcement Bar Text",
        "default": "✨ Free Shipping on Orders Above ₹1499 | Empowering Rural Artisans"
      },
      {
        "type": "color",
        "id": "announcement_bg",
        "label": "Announcement Bar Background",
        "default": "#2C2C2C"
      },
      {
        "type": "color",
        "id": "announcement_text_color",
        "label": "Announcement Bar Text Color",
        "default": "#C9A96E"
      },
      {
        "type": "checkbox",
        "id": "sticky_header",
        "label": "Enable Sticky Header",
        "default": true
      }
    ]
  },
  {
    "name": "Footer",
    "settings": [
      {
        "type": "text",
        "id": "footer_tagline",
        "label": "Footer Tagline",
        "default": "Stitch Your Calm. Wear the Story."
      },
      {
        "type": "text",
        "id": "footer_email",
        "label": "Contact Email",
        "default": "hello@aureliarituals.com"
      },
      {
        "type": "text",
        "id": "footer_whatsapp",
        "label": "WhatsApp Number",
        "default": "+91 98765 43210"
      },
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram Handle",
        "default": "@aureliarituals"
      },
      {
        "type": "text",
        "id": "social_instagram_url",
        "label": "Instagram URL",
        "default": "https://instagram.com/aureliarituals"
      },
      {
        "type": "text",
        "id": "social_pinterest_url",
        "label": "Pinterest URL",
        "default": "https://pinterest.com/aureliarituals"
      },
      {
        "type": "text",
        "id": "social_youtube_url",
        "label": "YouTube URL",
        "default": "https://youtube.com/@aureliarituals"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart Type",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ],
        "default": "drawer"
      }
    ]
  },
  {
    "name": "Product",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_artisan_note",
        "label": "Show Artisan Impact Note on Products",
        "default": true
      },
      {
        "type": "textarea",
        "id": "artisan_note_text",
        "label": "Artisan Impact Note",
        "default": "With every purchase, you support a skilled rural artisan and her family."
      }
    ]
  }
]
